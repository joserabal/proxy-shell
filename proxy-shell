#!/bin/bash
# proxy-shell: isolated shell where ALL traffic is routed through a SOCKS5 proxy
# Dependencies: sing-box, iproute2
# Usage: sudo proxy-shell [options] <host:port> [command]
#
NS="psh-$$"
TUN_DEV="tun$$"
TUN_GW="198.18.0.1"         # TUN interface IP inside the namespace
FAKE_RANGE="198.18.0.0/15"  # Fake IP range for DNS fakeip
PID_FILE="/tmp/singbox-${$}.pid"
LOG_FILE="/tmp/singbox-${$}.log"
CONF_FILE="/tmp/singbox-${$}.json"
RCFILE="/tmp/proxy-shell-rc-${$}"
PROXY_DNS=""                 # --dns: comma-separated DNS servers to use through proxy
LOCAL_DNS=0                  # --local-dns: resolve DNS locally, not through proxy
NO_PROXY=""                  # --no-proxy: comma-separated targets that bypass the proxy
NO_PROXY_DOMAINS=()          # populated from NO_PROXY: hostname/domain entries
NO_PROXY_CIDRS=()            # populated from NO_PROXY: IP/CIDR entries (always /N)
VERBOSE=1                    # 0 when a command is passed inline (non-interactive mode)

set -e

log() { [ "$VERBOSE" -eq 1 ] || return 0; echo "$@"; }

# ── Dependency check ────────────────────────────────────────────────────────

install_singbox() {
    echo "[*] Downloading sing-box..."
    local arch
    case "$(uname -m)" in
        x86_64)  arch="amd64"  ;;
        aarch64) arch="arm64"  ;;
        armv7l)  arch="armv7"  ;;
        *) echo "[!] Unsupported architecture: $(uname -m)"; exit 1 ;;
    esac

    local version
    version=$(curl -fsSL "https://api.github.com/repos/SagerNet/sing-box/releases/latest" \
              | grep '"tag_name"' | cut -d'"' -f4)
    local ver="${version#v}"
    local url="https://github.com/SagerNet/sing-box/releases/download/${version}/sing-box-${ver}-linux-${arch}.tar.gz"

    local tmp
    tmp=$(mktemp -d)
    curl -fsSL "$url" | tar -xz -C "$tmp"
    install -m 755 "$tmp"/sing-box-*/sing-box /usr/local/bin/sing-box
    rm -rf "$tmp"
    echo "[*] sing-box ${version} installed."
}

check_deps() {
    local missing=()

    command -v ip       &>/dev/null || missing+=("iproute2")
    command -v sing-box &>/dev/null || missing+=("sing-box")
    command -v curl     &>/dev/null || missing+=("curl")

    [ ${#missing[@]} -eq 0 ] && return 0

    echo ""
    echo "  Missing dependencies: ${missing[*]}"
    echo ""
    read -r -p "  Install now? [y/N] " answer </dev/tty
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
    echo ""

    for dep in "${missing[@]}"; do
        case "$dep" in
            iproute2|curl)
                echo "[*] Installing ${dep}..."
                apt-get install -y "$dep" -qq
                ;;
            sing-box)
                install_singbox
                ;;
        esac
    done
}

# ── Global install ──────────────────────────────────────────────────────────

global_install() {
    local target="/usr/local/bin/proxy-shell"
    local script
    script="$(realpath "$0")"

    if [ "$script" = "$target" ]; then
        echo "[!] Already running from ${target}, nothing to do."
        exit 0
    fi

    echo "[*] Installing proxy-shell to ${target}..."
    install -m 755 "$script" "$target"
    echo "[*] Done. You can now run: sudo proxy-shell"

    echo ""
    check_deps
}

# ── --no-proxy parsing ──────────────────────────────────────────────────────

# Classify each comma-separated entry into NO_PROXY_DOMAINS or NO_PROXY_CIDRS.
# IPv4 addresses without prefix are normalized to /32.
classify_no_proxy() {
    [ -z "$NO_PROXY" ] && return 0

    local entry entries
    IFS=',' read -ra entries <<< "$NO_PROXY"
    for entry in "${entries[@]}"; do
        entry="${entry// /}"
        [ -z "$entry" ] && continue

        if [[ "$entry" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+(/[0-9]+)?$ ]]; then
            [[ "$entry" == */* ]] || entry="${entry}/32"
            NO_PROXY_CIDRS+=("$entry")
        elif [[ "$entry" =~ ^[A-Za-z0-9.-]+$ ]]; then
            NO_PROXY_DOMAINS+=("$entry")
        else
            echo "[!] Invalid --no-proxy entry: '${entry}'"
            exit 1
        fi
    done
}

# Resolve every hostname in NO_PROXY_DOMAINS to its IPv4 addresses and append them
# as /32 CIDRs to NO_PROXY_CIDRS. This pre-resolution is what makes the bypass
# work for any protocol: route matching happens on the destination IP, so the
# kernel doesn't need to sniff Host/SNI to recognize the connection. The DNS rule
# still routes the hostname's queries to np-local so the app receives these same
# real IPs (rather than fakeip/proxy-resolved ones) and the routing matches.
resolve_no_proxy_domains() {
    [ ${#NO_PROXY_DOMAINS[@]} -eq 0 ] && return 0

    local domain ips ip
    for domain in "${NO_PROXY_DOMAINS[@]}"; do
        ips=$(getent ahostsv4 "$domain" 2>/dev/null | awk '{print $1}' | sort -u)
        if [ -z "$ips" ]; then
            echo "[!] Could not resolve --no-proxy hostname: '${domain}'"
            exit 1
        fi
        while IFS= read -r ip; do
            [ -n "$ip" ] && NO_PROXY_CIDRS+=("${ip}/32")
        done <<< "$ips"
    done
}

_json_string_array() {
    local out="[" first=1 v
    for v in "$@"; do
        [ $first -eq 0 ] && out+=", "
        out+="\"${v}\""
        first=0
    done
    out+="]"
    printf '%s' "$out"
}

_np_active() {
    [ ${#NO_PROXY_DOMAINS[@]} -gt 0 ] || [ ${#NO_PROXY_CIDRS[@]} -gt 0 ]
}

# Extra DNS server entry (with leading comma) used as the resolver for bypassed
# targets and as the domain_resolver of the direct outbound (required by
# sing-box 1.12+).
_np_dns_server_entry() {
    _np_active || return 0
    printf ', {"tag": "np-local", "type": "local"}'
}

# DNS rule (with trailing comma) routing bypassed hostnames to the local resolver.
# Must come before the catch-all DNS rules.
_np_dns_rule_prefix() {
    [ ${#NO_PROXY_DOMAINS[@]} -eq 0 ] && return 0
    local doms; doms=$(_json_string_array "${NO_PROXY_DOMAINS[@]}")
    printf '{"domain_suffix": %s, "server": "np-local"}, ' "$doms"
}

# Route rule (with leading comma) sending bypassed targets to the direct outbound.
# Hostnames have been pre-resolved into NO_PROXY_CIDRS, so a single ip_cidr rule
# covers every bypass entry — no domain_suffix matching (which would only work
# behind protocol sniffing) is needed.
_np_route_rules_suffix() {
    [ ${#NO_PROXY_CIDRS[@]} -eq 0 ] && return 0
    local cidrs; cidrs=$(_json_string_array "${NO_PROXY_CIDRS[@]}")
    printf ', {"ip_cidr": %s, "outbound": "direct"}' "$cidrs"
}

# Direct outbound entry (with leading comma). The explicit domain_resolver
# silences the sing-box 1.12+ deprecation that becomes fatal otherwise.
_np_outbound_entry() {
    _np_active || return 0
    printf ', {"type": "direct", "tag": "direct", "domain_resolver": "np-local"}'
}

# ── Config generation ────────────────────────────────────────────────────────

# Default mode: fake IP DNS — hostnames resolved by the remote proxy.
# Tools see fake IPs (198.18.0.0/15), not real ones.
_gen_fakeip_config() {
    local prefix="$1"
    cat > "$CONF_FILE" <<EOF
{
  "log": {"level": "warn"},
  "dns": {
    "servers": [
      {"tag": "fp",     "type": "fakeip", "inet4_range": "${FAKE_RANGE}"},
      {"tag": "remote", "type": "tcp",    "server": "8.8.8.8", "detour": "proxy"}$(_np_dns_server_entry)
    ],
    "rules": [$(_np_dns_rule_prefix){"query_type": ["A", "AAAA"], "server": "fp"}],
    "final": "remote"
  },
  "inbounds": [{
    "type": "tun",
    "interface_name": "${TUN_DEV}",
    "address": ["${TUN_GW}/${prefix}"],
    "mtu": 9000,
    "auto_route": false,
    "stack": "gvisor"
  }],
  "outbounds": [{
    "type": "socks",
    "tag": "proxy",
    "server": "${PROXY_HOST}",
    "server_port": ${PROXY_PORT},
    "version": "5"
  }$(_np_outbound_entry)],
  "route": {
    "rules": [{"port": 53, "action": "hijack-dns"}$(_np_route_rules_suffix)],
    "final": "proxy"
  }
}
EOF
}

# --dns mode: DNS resolved via specified servers, routed through the proxy.
# Tools see real IPs. Requires a DNS server reachable through the proxy
# that knows about the target hostnames (e.g. an internal corporate DNS).
_gen_proxy_dns_config() {
    local prefix="$1"

    # Build JSON server entries from comma-separated PROXY_DNS list
    local servers_json=""
    local i=0
    IFS=',' read -ra dns_list <<< "$PROXY_DNS"
    for srv in "${dns_list[@]}"; do
        srv="${srv// /}"
        [ $i -gt 0 ] && servers_json+=$',\n      '
        servers_json+="{\"tag\": \"remote-${i}\", \"type\": \"tcp\", \"server\": \"${srv}\", \"detour\": \"proxy\"}"
        ((i++)) || true
    done

    cat > "$CONF_FILE" <<EOF
{
  "log": {"level": "warn"},
  "dns": {
    "servers": [
      ${servers_json}$(_np_dns_server_entry)
    ],
    "rules": [$(_np_dns_rule_prefix){"query_type": ["A", "AAAA"], "server": "remote-0"}],
    "final": "remote-0"
  },
  "inbounds": [{
    "type": "tun",
    "interface_name": "${TUN_DEV}",
    "address": ["${TUN_GW}/${prefix}"],
    "mtu": 9000,
    "auto_route": false,
    "stack": "gvisor"
  }],
  "outbounds": [{
    "type": "socks",
    "tag": "proxy",
    "server": "${PROXY_HOST}",
    "server_port": ${PROXY_PORT},
    "version": "5"
  }$(_np_outbound_entry)],
  "route": {
    "rules": [{"port": 53, "action": "hijack-dns"}$(_np_route_rules_suffix)],
    "final": "proxy"
  }
}
EOF
}

# --local-dns mode: DNS resolved by the local machine's resolver (not through proxy).
# Tools see real IPs. DNS queries are not tunneled — may leak to local network.
_gen_local_dns_config() {
    local prefix="$1"

    cat > "$CONF_FILE" <<EOF
{
  "log": {"level": "warn"},
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"}$(_np_dns_server_entry)
    ],
    "rules": [$(_np_dns_rule_prefix){"query_type": ["A", "AAAA"], "server": "local"}],
    "final": "local"
  },
  "inbounds": [{
    "type": "tun",
    "interface_name": "${TUN_DEV}",
    "address": ["${TUN_GW}/${prefix}"],
    "mtu": 9000,
    "auto_route": false,
    "stack": "gvisor"
  }],
  "outbounds": [{
    "type": "socks",
    "tag": "proxy",
    "server": "${PROXY_HOST}",
    "server_port": ${PROXY_PORT},
    "version": "5"
  }$(_np_outbound_entry)],
  "route": {
    "rules": [{"port": 53, "action": "hijack-dns"}$(_np_route_rules_suffix)],
    "final": "proxy"
  }
}
EOF
}

generate_config() {
    local prefix="${FAKE_RANGE##*/}"
    if [ -n "$PROXY_DNS" ]; then
        _gen_proxy_dns_config "$prefix"
    elif [ "$LOCAL_DNS" -eq 1 ]; then
        _gen_local_dns_config "$prefix"
    else
        _gen_fakeip_config "$prefix"
    fi
}

# ── Setup / teardown ─────────────────────────────────────────────────────────

setup() {
    log "[*] Creating network namespace..."
    ip netns add "$NS"

    log "[*] Starting sing-box..."
    generate_config
    # sing-box runs in the HOST namespace: direct access to PROXY_HOST:PROXY_PORT
    sing-box run -c "$CONF_FILE" &>"$LOG_FILE" &
    echo $! > "$PID_FILE"

    sleep 1
    if ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "[!] sing-box failed to start:"
        cat "$LOG_FILE"
        exit 1
    fi

    log "[*] Moving TUN into proxy namespace..."
    # sing-box keeps its fd valid even after the interface moves to another namespace
    ip link set "$TUN_DEV" netns "$NS"
    ip netns exec "$NS" ip addr add "${TUN_GW}/15" dev "$TUN_DEV"
    ip netns exec "$NS" ip link set "$TUN_DEV" up
    ip netns exec "$NS" ip link set lo up
    ip netns exec "$NS" ip route add default dev "$TUN_DEV"

    log "[*] Configuring namespace DNS..."
    mkdir -p /etc/netns/"$NS"
    # Placeholder — sing-box intercepts all DNS on port 53 before it leaves the namespace
    echo "nameserver 8.8.8.8" > /etc/netns/"$NS"/resolv.conf

    local dns_label
    if [ -n "$PROXY_DNS" ]; then
        dns_label="real IPs via proxy (${PROXY_DNS})"
    elif [ "$LOCAL_DNS" -eq 1 ]; then
        dns_label="real IPs via local resolver (not tunneled)"
    else
        dns_label="fake IP — resolved by remote proxy"
    fi

    log ""
    log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    log " Proxified shell active"
    log " SOCKS5 proxy : ${PROXY_HOST}:${PROXY_PORT}"
    log " DNS          : ${dns_label}"
    if [ ${#NO_PROXY_DOMAINS[@]} -gt 0 ] || [ ${#NO_PROXY_CIDRS[@]} -gt 0 ]; then
        log " No-proxy     : ${NO_PROXY_DOMAINS[*]} ${NO_PROXY_CIDRS[*]}"
    fi
    log "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

teardown() {
    log ""
    log "[*] Cleaning up..."
    kill "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null || true
    ip netns del "$NS" 2>/dev/null || true
    ip link del "$TUN_DEV" 2>/dev/null || true
    rm -f "$PID_FILE" "$LOG_FILE" "$CONF_FILE" "$RCFILE"
    rm -f /etc/netns/"$NS"/resolv.conf
    rmdir /etc/netns/"$NS" 2>/dev/null || true
    log "[*] Done."
}

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
    echo "Usage: sudo proxy-shell [options] <host:port> [command]"
    echo ""
    echo "  host:port   SOCKS5 proxy address (e.g. 127.0.0.1:8888)"
    echo "  command     Optional command to run inside the proxified namespace."
    echo "              If omitted, opens an interactive shell — ALL traffic from"
    echo "              every command you run will be transparently proxified."
    echo ""
    echo "Options:"
    echo "  --dns <servers>    Comma-separated DNS servers to use, routed through the proxy."
    echo "                     Tools see real IPs instead of fake ones. Use when you need"
    echo "                     real IPs in output or reports. Requires a DNS server"
    echo "                     reachable through the proxy (e.g. an internal corporate DNS)."
    echo "                     Example: --dns 10.0.0.53"
    echo "                              --dns 10.0.0.53,10.0.0.54"
    echo ""
    echo "  --local-dns        Resolve DNS using the local machine's resolver, not through"
    echo "                     the proxy. Tools see real IPs but DNS queries are not tunneled."
    echo "                     Note: --dns and --local-dns are mutually exclusive."
    echo ""
    echo "  --no-proxy <list>  Comma-separated targets that bypass the proxy and connect"
    echo "                     directly. Accepts hostnames, IPv4 addresses, and CIDR ranges."
    echo "                     Hostnames are resolved at startup and bypass is matched on the"
    echo "                     resulting IPs (works for any protocol — TCP, UDP, raw sockets)."
    echo "                     Requires --dns or --local-dns: in the default fakeip mode the"
    echo "                     client only sees fake IPs, so IP-based route matching cannot"
    echo "                     identify bypassed targets."
    echo "                     Example: --no-proxy example.com,10.0.0.0/8,192.168.1.1"
    echo ""
    echo "  --global-install   Copy this script to /usr/local/bin and check dependencies."
    echo ""
    echo "Examples:"
    echo "  # Open a proxified interactive shell:"
    echo "  sudo proxy-shell 127.0.0.1:8888"
    echo ""
    echo "  # Run a single command through the proxy:"
    echo "  sudo proxy-shell 127.0.0.1:8888 curl https://ifconfig.me"
    echo ""
    echo "  # Use a specific DNS server to get real IPs in tool output:"
    echo "  sudo proxy-shell --dns 10.0.0.53 127.0.0.1:8888"
    echo ""
    echo "  # Bypass the proxy for a corporate network and a specific host:"
    echo "  sudo proxy-shell --local-dns --no-proxy 10.0.0.0/8,internal.corp 127.0.0.1:8888"
    exit 1
}

# ── Entry point ──────────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
    usage
fi

if [ "$EUID" -ne 0 ]; then
    echo "[!] This script must be run as root."
    echo "    Try: sudo $0 $*"
    exit 1
fi

# Parse options
while [[ "${1:-}" == --* ]]; do
    case "${1}" in
        --dns)
            [ -z "${2:-}" ] && { echo "[!] --dns requires an argument."; echo ""; usage; }
            [ "$LOCAL_DNS" -eq 1 ] && { echo "[!] --dns and --local-dns are mutually exclusive."; echo ""; usage; }
            PROXY_DNS="${2}"
            shift 2
            ;;
        --local-dns)
            [ -n "$PROXY_DNS" ] && { echo "[!] --dns and --local-dns are mutually exclusive."; echo ""; usage; }
            LOCAL_DNS=1
            shift
            ;;
        --no-proxy)
            [ -z "${2:-}" ] && { echo "[!] --no-proxy requires an argument."; echo ""; usage; }
            NO_PROXY="${2}"
            shift 2
            ;;
        --global-install)
            global_install
            exit 0
            ;;
        *)
            echo "[!] Unknown option: ${1}"
            echo ""
            usage
            ;;
    esac
done

# --no-proxy needs real IPs at the kernel level for IP-based route matching to
# work. The default fakeip mode delivers fake IPs (198.18.0.0/15) to clients,
# so the kernel never sees the bypass IPs and the route rule never matches.
if [ -n "$NO_PROXY" ] && [ -z "$PROXY_DNS" ] && [ "$LOCAL_DNS" -eq 0 ]; then
    echo "[!] --no-proxy requires --dns or --local-dns."
    echo "    The default fakeip mode delivers fake IPs to the client, so IP-based"
    echo "    bypass routing cannot match the real destination addresses."
    echo ""
    usage
fi

# Parse host:port
PROXY_ADDR="${1}"
PROXY_HOST="${PROXY_ADDR%%:*}"
PROXY_PORT="${PROXY_ADDR##*:}"

if [ -z "$PROXY_HOST" ] || [ -z "$PROXY_PORT" ] || [ "$PROXY_HOST" = "$PROXY_ADDR" ]; then
    echo "[!] Invalid proxy address: '${PROXY_ADDR}' — expected host:port"
    echo ""
    usage
fi

if ! [[ "$PROXY_PORT" =~ ^[0-9]+$ ]] || [ "$PROXY_PORT" -lt 1 ] || [ "$PROXY_PORT" -gt 65535 ]; then
    echo "[!] Invalid port: '${PROXY_PORT}' — must be a number between 1 and 65535"
    echo ""
    usage
fi

# Resolve hostname to IP — sing-box requires a numeric address for outbound servers
if ! [[ "$PROXY_HOST" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    RESOLVED=$(getent hosts "$PROXY_HOST" 2>/dev/null | awk '{print $1; exit}')
    if [ -z "$RESOLVED" ]; then
        echo "[!] Could not resolve hostname: '${PROXY_HOST}'"
        exit 1
    fi
    PROXY_HOST="$RESOLVED"
fi

shift  # remove host:port from "$@"; remaining args are the optional command
[ $# -gt 0 ] && VERBOSE=0

# Clean up orphaned /etc/netns entries from previous crashed instances
for dir in /etc/netns/psh-*/; do
    ns="${dir%/}"
    ns="${ns##*/}"
    if ! ip netns list | grep -q "^${ns} "; then
        rm -f "${dir}resolv.conf"
        rmdir "$dir" 2>/dev/null || true
    fi
done

classify_no_proxy
resolve_no_proxy_domains

check_deps

trap teardown EXIT

setup

if [ $# -eq 0 ]; then
    cat > "$RCFILE" <<'RCEOF'
force_color_prompt=yes
[ -f ~/.bashrc ] && source ~/.bashrc
PS1='\[\e[38;5;232m\]\[\e[48;5;82m\] proxified \[\e[0m\]\[\e[38;5;82m\]❯\[\e[0m\] \[\e[1;34m\]\w\[\e[0m\] \$ '
RCEOF
    chown "$SUDO_USER" "$RCFILE"
    ip netns exec "$NS" sudo -u "$SUDO_USER" \
        env TERM="${TERM:-xterm-256color}" \
        bash --rcfile "$RCFILE"
else
    ip netns exec "$NS" sudo -u "$SUDO_USER" "$@"
fi

