#!/bin/bash
# proxy-shell: isolated shell where ALL traffic is routed through a SOCKS5 proxy
# Dependencies: sing-box, iproute2
# Usage: sudo proxy-shell [options] <host:port> [command]
#
NS="psh-$$"
TUN_DEV="tun$$"
TUN_GW="198.18.0.1"         # TUN interface IP inside the namespace
FAKE_RANGE="198.18.0.0/15"  # Fake IP range for DNS fakeip
PID_FILE="/tmp/singbox-${$}.pid"
LOG_FILE="/tmp/singbox-${$}.log"
CONF_FILE="/tmp/singbox-${$}.json"
RCFILE="/tmp/proxy-shell-rc-${$}"
PROXY_DNS=""                 # --dns: comma-separated DNS servers to use through proxy
LOCAL_DNS=0                  # --local-dns: resolve DNS locally, not through proxy

set -e

# ── Dependency check ────────────────────────────────────────────────────────

install_singbox() {
    echo "[*] Downloading sing-box..."
    local arch
    case "$(uname -m)" in
        x86_64)  arch="amd64"  ;;
        aarch64) arch="arm64"  ;;
        armv7l)  arch="armv7"  ;;
        *) echo "[!] Unsupported architecture: $(uname -m)"; exit 1 ;;
    esac

    local version
    version=$(curl -fsSL "https://api.github.com/repos/SagerNet/sing-box/releases/latest" \
              | grep '"tag_name"' | cut -d'"' -f4)
    local ver="${version#v}"
    local url="https://github.com/SagerNet/sing-box/releases/download/${version}/sing-box-${ver}-linux-${arch}.tar.gz"

    local tmp
    tmp=$(mktemp -d)
    curl -fsSL "$url" | tar -xz -C "$tmp"
    install -m 755 "$tmp"/sing-box-*/sing-box /usr/local/bin/sing-box
    rm -rf "$tmp"
    echo "[*] sing-box ${version} installed."
}

check_deps() {
    local missing=()

    command -v ip       &>/dev/null || missing+=("iproute2")
    command -v sing-box &>/dev/null || missing+=("sing-box")
    command -v curl     &>/dev/null || missing+=("curl")

    [ ${#missing[@]} -eq 0 ] && return 0

    echo ""
    echo "  Missing dependencies: ${missing[*]}"
    echo ""
    read -r -p "  Install now? [y/N] " answer </dev/tty
    [[ "$answer" =~ ^[Yy]$ ]] || { echo "Aborted."; exit 1; }
    echo ""

    for dep in "${missing[@]}"; do
        case "$dep" in
            iproute2|curl)
                echo "[*] Installing ${dep}..."
                apt-get install -y "$dep" -qq
                ;;
            sing-box)
                install_singbox
                ;;
        esac
    done
}

# ── Global install ──────────────────────────────────────────────────────────

global_install() {
    local target="/usr/local/bin/proxy-shell"
    local script
    script="$(realpath "$0")"

    if [ "$script" = "$target" ]; then
        echo "[!] Already running from ${target}, nothing to do."
        exit 0
    fi

    echo "[*] Installing proxy-shell to ${target}..."
    install -m 755 "$script" "$target"
    echo "[*] Done. You can now run: sudo proxy-shell"

    echo ""
    check_deps
}

# ── Config generation ────────────────────────────────────────────────────────

# Default mode: fake IP DNS — hostnames resolved by the remote proxy.
# Tools see fake IPs (198.18.0.0/15), not real ones.
_gen_fakeip_config() {
    local prefix="$1"
    cat > "$CONF_FILE" <<EOF
{
  "log": {"level": "warn"},
  "dns": {
    "servers": [
      {"tag": "fp",     "type": "fakeip", "inet4_range": "${FAKE_RANGE}"},
      {"tag": "remote", "type": "tcp",    "server": "8.8.8.8", "detour": "proxy"}
    ],
    "rules": [{"query_type": ["A", "AAAA"], "server": "fp"}],
    "final": "remote"
  },
  "inbounds": [{
    "type": "tun",
    "interface_name": "${TUN_DEV}",
    "address": ["${TUN_GW}/${prefix}"],
    "mtu": 9000,
    "auto_route": false,
    "stack": "gvisor"
  }],
  "outbounds": [{
    "type": "socks",
    "tag": "proxy",
    "server": "${PROXY_HOST}",
    "server_port": ${PROXY_PORT},
    "version": "5"
  }],
  "route": {
    "rules": [{"port": 53, "action": "hijack-dns"}],
    "final": "proxy"
  }
}
EOF
}

# --dns mode: DNS resolved via specified servers, routed through the proxy.
# Tools see real IPs. Requires a DNS server reachable through the proxy
# that knows about the target hostnames (e.g. an internal corporate DNS).
_gen_proxy_dns_config() {
    local prefix="$1"

    # Build JSON server entries from comma-separated PROXY_DNS list
    local servers_json=""
    local i=0
    IFS=',' read -ra dns_list <<< "$PROXY_DNS"
    for srv in "${dns_list[@]}"; do
        srv="${srv// /}"
        [ $i -gt 0 ] && servers_json+=$',\n      '
        servers_json+="{\"tag\": \"remote-${i}\", \"type\": \"tcp\", \"server\": \"${srv}\", \"detour\": \"proxy\"}"
        ((i++)) || true
    done

    cat > "$CONF_FILE" <<EOF
{
  "log": {"level": "warn"},
  "dns": {
    "servers": [
      ${servers_json}
    ],
    "rules": [{"query_type": ["A", "AAAA"], "server": "remote-0"}],
    "final": "remote-0"
  },
  "inbounds": [{
    "type": "tun",
    "interface_name": "${TUN_DEV}",
    "address": ["${TUN_GW}/${prefix}"],
    "mtu": 9000,
    "auto_route": false,
    "stack": "gvisor"
  }],
  "outbounds": [{
    "type": "socks",
    "tag": "proxy",
    "server": "${PROXY_HOST}",
    "server_port": ${PROXY_PORT},
    "version": "5"
  }],
  "route": {
    "rules": [{"port": 53, "action": "hijack-dns"}],
    "final": "proxy"
  }
}
EOF
}

# --local-dns mode: DNS resolved by the local machine's resolver (not through proxy).
# Tools see real IPs. DNS queries are not tunneled — may leak to local network.
_gen_local_dns_config() {
    local prefix="$1"

    cat > "$CONF_FILE" <<EOF
{
  "log": {"level": "warn"},
  "dns": {
    "servers": [
      {"tag": "local", "type": "local"}
    ],
    "rules": [{"query_type": ["A", "AAAA"], "server": "local"}],
    "final": "local"
  },
  "inbounds": [{
    "type": "tun",
    "interface_name": "${TUN_DEV}",
    "address": ["${TUN_GW}/${prefix}"],
    "mtu": 9000,
    "auto_route": false,
    "stack": "gvisor"
  }],
  "outbounds": [{
    "type": "socks",
    "tag": "proxy",
    "server": "${PROXY_HOST}",
    "server_port": ${PROXY_PORT},
    "version": "5"
  }],
  "route": {
    "rules": [{"port": 53, "action": "hijack-dns"}],
    "final": "proxy"
  }
}
EOF
}

generate_config() {
    local prefix="${FAKE_RANGE##*/}"
    if [ -n "$PROXY_DNS" ]; then
        _gen_proxy_dns_config "$prefix"
    elif [ "$LOCAL_DNS" -eq 1 ]; then
        _gen_local_dns_config "$prefix"
    else
        _gen_fakeip_config "$prefix"
    fi
}

# ── Setup / teardown ─────────────────────────────────────────────────────────

setup() {
    echo "[*] Creating network namespace..."
    ip netns add "$NS"

    echo "[*] Starting sing-box..."
    generate_config
    # sing-box runs in the HOST namespace: direct access to PROXY_HOST:PROXY_PORT
    sing-box run -c "$CONF_FILE" &>"$LOG_FILE" &
    echo $! > "$PID_FILE"

    sleep 1
    if ! kill -0 "$(cat "$PID_FILE")" 2>/dev/null; then
        echo "[!] sing-box failed to start:"
        cat "$LOG_FILE"
        exit 1
    fi

    echo "[*] Moving TUN into proxy namespace..."
    # sing-box keeps its fd valid even after the interface moves to another namespace
    ip link set "$TUN_DEV" netns "$NS"
    ip netns exec "$NS" ip addr add "${TUN_GW}/15" dev "$TUN_DEV"
    ip netns exec "$NS" ip link set "$TUN_DEV" up
    ip netns exec "$NS" ip link set lo up
    ip netns exec "$NS" ip route add default dev "$TUN_DEV"

    echo "[*] Configuring namespace DNS..."
    mkdir -p /etc/netns/"$NS"
    # Placeholder — sing-box intercepts all DNS on port 53 before it leaves the namespace
    echo "nameserver 8.8.8.8" > /etc/netns/"$NS"/resolv.conf

    local dns_label
    if [ -n "$PROXY_DNS" ]; then
        dns_label="real IPs via proxy (${PROXY_DNS})"
    elif [ "$LOCAL_DNS" -eq 1 ]; then
        dns_label="real IPs via local resolver (not tunneled)"
    else
        dns_label="fake IP — resolved by remote proxy"
    fi

    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    echo " Proxified shell active"
    echo " SOCKS5 proxy : ${PROXY_HOST}:${PROXY_PORT}"
    echo " DNS          : ${dns_label}"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
}

teardown() {
    echo ""
    echo "[*] Cleaning up..."
    kill "$(cat "$PID_FILE" 2>/dev/null)" 2>/dev/null || true
    ip netns del "$NS" 2>/dev/null || true
    ip link del "$TUN_DEV" 2>/dev/null || true
    rm -f "$PID_FILE" "$LOG_FILE" "$CONF_FILE" "$RCFILE"
    rm -f /etc/netns/"$NS"/resolv.conf
    rmdir /etc/netns/"$NS" 2>/dev/null || true
    echo "[*] Done."
}

# ── Usage ────────────────────────────────────────────────────────────────────

usage() {
    echo "Usage: sudo proxy-shell [options] <host:port> [command]"
    echo ""
    echo "  host:port   SOCKS5 proxy address (e.g. 127.0.0.1:8888)"
    echo "  command     Optional command to run inside the proxified namespace."
    echo "              If omitted, opens an interactive shell — ALL traffic from"
    echo "              every command you run will be transparently proxified."
    echo ""
    echo "Options:"
    echo "  --dns <servers>    Comma-separated DNS servers to use, routed through the proxy."
    echo "                     Tools see real IPs instead of fake ones. Use when you need"
    echo "                     real IPs in output or reports. Requires a DNS server"
    echo "                     reachable through the proxy (e.g. an internal corporate DNS)."
    echo "                     Example: --dns 10.0.0.53"
    echo "                              --dns 10.0.0.53,10.0.0.54"
    echo ""
    echo "  --local-dns        Resolve DNS using the local machine's resolver, not through"
    echo "                     the proxy. Tools see real IPs but DNS queries are not tunneled."
    echo "                     Note: --dns and --local-dns are mutually exclusive."
    echo ""
    echo "  --global-install   Copy this script to /usr/local/bin and check dependencies."
    echo ""
    echo "Examples:"
    echo "  # Open a proxified interactive shell:"
    echo "  sudo proxy-shell 127.0.0.1:8888"
    echo ""
    echo "  # Run a single command through the proxy:"
    echo "  sudo proxy-shell 127.0.0.1:8888 curl https://ifconfig.me"
    echo ""
    echo "  # Use a specific DNS server to get real IPs in tool output:"
    echo "  sudo proxy-shell --dns 10.0.0.53 127.0.0.1:8888"
    exit 1
}

# ── Entry point ──────────────────────────────────────────────────────────────

if [ $# -eq 0 ]; then
    usage
fi

if [ "$EUID" -ne 0 ]; then
    echo "[!] This script must be run as root."
    echo "    Try: sudo $0 $*"
    exit 1
fi

# Parse options
while [[ "${1:-}" == --* ]]; do
    case "${1}" in
        --dns)
            [ -z "${2:-}" ] && { echo "[!] --dns requires an argument."; echo ""; usage; }
            [ "$LOCAL_DNS" -eq 1 ] && { echo "[!] --dns and --local-dns are mutually exclusive."; echo ""; usage; }
            PROXY_DNS="${2}"
            shift 2
            ;;
        --local-dns)
            [ -n "$PROXY_DNS" ] && { echo "[!] --dns and --local-dns are mutually exclusive."; echo ""; usage; }
            LOCAL_DNS=1
            shift
            ;;
        --global-install)
            global_install
            exit 0
            ;;
        *)
            echo "[!] Unknown option: ${1}"
            echo ""
            usage
            ;;
    esac
done

# Parse host:port
PROXY_ADDR="${1}"
PROXY_HOST="${PROXY_ADDR%%:*}"
PROXY_PORT="${PROXY_ADDR##*:}"

if [ -z "$PROXY_HOST" ] || [ -z "$PROXY_PORT" ] || [ "$PROXY_HOST" = "$PROXY_ADDR" ]; then
    echo "[!] Invalid proxy address: '${PROXY_ADDR}' — expected host:port"
    echo ""
    usage
fi

if ! [[ "$PROXY_PORT" =~ ^[0-9]+$ ]] || [ "$PROXY_PORT" -lt 1 ] || [ "$PROXY_PORT" -gt 65535 ]; then
    echo "[!] Invalid port: '${PROXY_PORT}' — must be a number between 1 and 65535"
    echo ""
    usage
fi

# Resolve hostname to IP — sing-box requires a numeric address for outbound servers
if ! [[ "$PROXY_HOST" =~ ^[0-9]+\.[0-9]+\.[0-9]+\.[0-9]+$ ]]; then
    RESOLVED=$(getent hosts "$PROXY_HOST" 2>/dev/null | awk '{print $1; exit}')
    if [ -z "$RESOLVED" ]; then
        echo "[!] Could not resolve hostname: '${PROXY_HOST}'"
        exit 1
    fi
    PROXY_HOST="$RESOLVED"
fi

shift  # remove host:port from "$@"; remaining args are the optional command

# Clean up orphaned /etc/netns entries from previous crashed instances
for dir in /etc/netns/psh-*/; do
    ns="${dir%/}"
    ns="${ns##*/}"
    if ! ip netns list | grep -q "^${ns} "; then
        rm -f "${dir}resolv.conf"
        rmdir "$dir" 2>/dev/null || true
    fi
done

check_deps

trap teardown EXIT

setup

if [ $# -eq 0 ]; then
    cat > "$RCFILE" <<'RCEOF'
force_color_prompt=yes
[ -f ~/.bashrc ] && source ~/.bashrc
PS1='\[\e[38;5;232m\]\[\e[48;5;82m\] proxified \[\e[0m\]\[\e[38;5;82m\]❯\[\e[0m\] \[\e[1;34m\]\w\[\e[0m\] \$ '
RCEOF
    chown "$SUDO_USER" "$RCFILE"
    ip netns exec "$NS" sudo -u "$SUDO_USER" \
        env TERM="${TERM:-xterm-256color}" \
        bash --rcfile "$RCFILE"
else
    ip netns exec "$NS" sudo -u "$SUDO_USER" "$@"
fi

